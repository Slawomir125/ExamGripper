sql="INSERT IGNORE INTO bloki_kodu (id, id_pytania, kod, poprzedni_blok_id, czy_jest_wymagane) VALUES\r\n  (1, 1, 'def silnia(n):', NULL, 1),\r\n  (2, 1, '    if n <= 1:', 1, 1),\r\n  (3, 1, '        return 1', 2, 1),\r\n  (4, 1, '    else:', 3, 1),\r\n  (5, 1, '        return n * silnia(n - 1)', 4, 1),\r\n  (6, 2, 'def fib(n):', NULL, 1),\r\n  (7, 2, '    if n <= 1:', 6, 1),\r\n  (8, 2, '        return n', 7, 1),\r\n  (9, 2, '    a, b = 0, 1', 8, 1),\r\n  (10, 2, '    for i in range(2, n + 1):', 9, 1),\r\n  (11, 2, '        a, b = b, a + b', 10, 1),\r\n  (12, 2, '    return b', 11, 1),\r\n  (13, 3, 'def bubble_sort(arr):', NULL, 1),\r\n  (14, 3, '    n = len(arr)', 13, 1),\r\n  (15, 3, '    for i in range(n):', 14, 1),\r\n  (16, 3, '        for j in range(0, n - i - 1):', 15, 1),\r\n  (17, 3, '            if arr[j] > arr[j + 1]:', 16, 1),\r\n  (18, 3, '                arr[j], arr[j + 1] = arr[j + 1], arr[j]', 17, 1),\r\n  (19, 3, '    return arr', 18, 1),\r\n  (20, 4, 'def is_palindrome(s):', NULL, 1),\r\n  (21, 4, '    s = s.lower().replace(\" \", \"\")', 20, 1),\r\n  (22, 4, '    if not s:', 21, 1),\r\n  (23, 4, '        return True', 22, 1),\r\n  (24, 4, '    return s == s[::-1]', 23, 1),\r\n  (25, 5, 'def find_max(arr):', NULL, 1),\r\n  (26, 5, '    if not arr:', 25, 1),\r\n  (27, 5, '        return None', 26, 1),\r\n  (28, 5, '    max_val = arr[0]', 27, 1),\r\n  (29, 5, '    for x in arr:', 28, 1),\r\n  (30, 5, '        if x > max_val:', 29, 1),\r\n  (31, 5, '            max_val = x', 30, 1),\r\n  (32, 5, '    return max_val', 31, 1),\r\n  (33, 6, 'def sum_array(arr):', NULL, 1),\r\n  (34, 6, '    suma = 0', 33, 1),\r\n  (35, 6, '    for x in arr:', 34, 1),\r\n  (36, 6, '        suma += x', 35, 1),\r\n  (37, 6, '    return suma', 36, 1),\r\n  (38, 7, 'def is_prime(n):', NULL, 1),\r\n  (39, 7, '    if n <= 1:', 38, 1),\r\n  (40, 7, '        return False', 39, 1),\r\n  (41, 7, '    for i in range(2, int(n0.5) + 1):', 40, 1),\r\n  (42, 7, '        if n % i == 0:', 41, 1),\r\n  (43, 7, '            return False', 42, 1),\r\n  (44, 7, '    return True', 43, 1),\r\n  (45, 8, 'def reverse_string(s):', NULL, 1),\r\n  (46, 8, '    if not s:', 45, 1),\r\n  (47, 8, '        return \"\"', 46, 1),\r\n  (48, 8, '    return s[::-1]', 47, 1),\r\n  (49, 9, 'def average(arr):', NULL, 1),\r\n  (50, 9, '    if not arr:', 49, 1),\r\n  (51, 9, '        return 0', 50, 1),\r\n  (52, 9, '    suma = 0', 51, 1),\r\n  (53, 9, '    for x in arr:', 52, 1),\r\n  (54, 9, '        suma += x', 53, 1),\r\n  (55, 9, '    return suma / len(arr)', 54, 1),\r\n  (56, 10, 'public static long silnia(int n) {', NULL, 1),\r\n  (57, 10, '    if (n <= 1) return 1;', 56, 1),\r\n  (58, 10, '    long result = 1;', 57, 1),\r\n  (59, 10, '    for (int i = 2; i <= n; i++) {', 58, 1),\r\n  (60, 10, '        result *= i;', 59, 1),\r\n  (61, 10, '    }', 60, 1),\r\n  (62, 10, '    return result;', 61, 1),\r\n  (63, 11, 'public static int fib(int n) {', NULL, 1),\r\n  (64, 11, '    if (n <= 1) return n;', 63, 1),\r\n  (65, 11, '    int a = 0, b = 1;', 64, 1),\r\n  (66, 11, '    for (int i = 2; i <= n; i++) {', 65, 1),\r\n  (67, 11, '        int temp = a + b;', 66, 1),\r\n  (68, 11, '        a = b;', 67, 1),\r\n  (69, 11, '        b = temp;', 68, 1),\r\n  (70, 11, '    }', 69, 1),\r\n  (71, 11, '    return b;', 70, 1),\r\n  (72, 12, 'public static void bubbleSort(int[] arr) {', NULL, 1),\r\n  (73, 12, '    int n = arr.length;', 72, 1),\r\n  (74, 12, '    for (int i = 0; i < n - 1; i++) {', 73, 1),\r\n  (75, 12, '        for (int j = 0; j < n - i - 1; j++) {', 74, 1),\r\n  (76, 12, '            if (arr[j] > arr[j + 1]) {', 75, 1),\r\n  (77, 12, '                int temp = arr[j];', 76, 1),\r\n  (78, 12, '                arr[j] = arr[j + 1];', 77, 1),\r\n  (79, 12, '                arr[j + 1] = temp;', 78, 1),\r\n  (80, 12, '            }', 79, 1),\r\n  (81, 12, '        }', 80, 1),\r\n  (82, 12, '    }', 81, 1),\r\n  (83, 12, '}', 82, 1),\r\n  (84, 13, 'public static boolean isPalindrome(String s) {', NULL, 1),\r\n  (85, 13, '    s = s.toLowerCase().replaceAll(\"\\\\\\\\s+\", \"\");', 84, 1),\r\n  (86, 13, '    int left = 0, right = s.length() - 1;', 85, 1),\r\n  (87, 13, '    while (left < right) {', 86, 1),\r\n  (88, 13, '        if (s.charAt(left) != s.charAt(right)) return false;', 87, 1),\r\n  (89, 13, '        left++;', 88, 1),\r\n  (90, 13, '        right--;', 89, 1),\r\n  (91, 13, '    }', 90, 1),\r\n  (92, 13, '    return true;', 91, 1),\r\n  (93, 13, '}', 92, 1),\r\n  (94, 14, 'public static int findMax(int[] arr) {', NULL, 1),\r\n  (95, 14, '    if (arr.length == 0) return Integer.MIN_VALUE;', 94, 1),\r\n  (96, 14, '    int max = arr[0];', 95, 1),\r\n  (97, 14, '    for (int i = 1; i < arr.length; i++) {', 96, 1),\r\n  (98, 14, '        if (arr[i] > max) max = arr[i];', 97, 1),\r\n  (99, 14, '    }', 98, 1),\r\n  (100, 14, '    return max;', 99, 1),\r\n  (101, 14, '}', 100, 1),\r\n  (102, 15, 'public static int sumArray(int[] arr) {', NULL, 1),\r\n  (103, 15, '    int sum = 0;', 102, 1),\r\n  (104, 15, '    for (int i = 0; i < arr.length; i++) {', 103, 1),\r\n  (105, 15, '        sum += arr[i];', 104, 1),\r\n  (106, 15, '    }', 105, 1),\r\n  (107, 15, '    return sum;', 106, 1),\r\n  (108, 15, '}', 107, 1),\r\n  (109, 16, 'public static boolean isPrime(int n) {', NULL, 1),\r\n  (110, 16, '    if (n <= 1) return false;', 109, 1),\r\n  (111, 16, '    for (int i = 2; i <= Math.sqrt(n); i++) {', 110, 1),\r\n  (112, 16, '        if (n % i == 0) return false;', 111, 1),\r\n  (113, 16, '    }', 112, 1),\r\n  (114, 16, '    return true;', 113, 1),\r\n  (115, 16, '}', 114, 1),\r\n  (116, 17, 'public static void reverseArray(int[] arr) {', NULL, 1),\r\n  (117, 17, '    int n = arr.length;', 116, 1),\r\n  (118, 17, '    for (int i = 0; i < n / 2; i++) {', 117, 1),\r\n  (119, 17, '        int temp = arr[i];', 118, 1),\r\n  (120, 17, '        arr[i] = arr[n - 1 - i];', 119, 1),\r\n  (121, 17, '        arr[n - 1 - i] = temp;', 120, 1),\r\n 