sql="INSERT IGNORE INTO pytania (id, id_kategorii, tresc) VALUES\r\n  (1, 1, 'Używając podanych elementów, uzupełnij kod funkcji obliczającej silnię rekurencyjnie w języku Python, aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n        return n * silnia(n - 1)\r\n    if n <= 1:\r\ndef silnia(n):\r\n        return 1\r\n    else:'),\r\n  (2, 1, 'Używając podanych elementów, uzupełnij kod funkcji obliczającej ciąg Fibonacciego iteracyjnie w języku Python, aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n    return b\r\n    for i in range(2, n + 1):\r\n    a, b = 0, 1\r\n    if n <= 1:\r\ndef fib(n):\r\n        a, b = b, a + b\r\n        return n'),\r\n  (3, 1, 'Używając podanych elementów, uzupełnij kod funkcji sortującej tablicę metodą bąbelkową w języku Python, aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n                arr[j], arr[j + 1] = arr[j + 1], arr[j]\r\n    for i in range(n):\r\n    n = len(arr)\r\ndef bubble_sort(arr):\r\n        for j in range(0, n - i - 1):\r\n            if arr[j] > arr[j + 1]:'),\r\n  (4, 1, 'Używając podanych elementów, uzupełnij kod funkcji sprawdzającej czy napis jest palindromem w języku Python, aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n    return s == s[::-1]\r\ndef is_palindrome(s):\r\n    s = s.lower().replace(\" \", \"\")\r\n    if not s:\r\n        return True'),\r\n  (5, 1, 'Używając podanych elementów, uzupełnij kod funkcji znajdującej największy element w liście w języku Python, aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n    if not arr:\r\n        return None\r\n    max_val = arr[0]\r\ndef find_max(arr):\r\n        for x in arr:\r\n            if x > max_val:\r\n                max_val = x\r\n    return max_val'),\r\n  (6, 1, 'Używając podanych elementów, uzupełnij kod funkcji obliczającej sumę elementów tablicy w języku Python, aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n    suma = 0\r\ndef sum_array(arr):\r\n        for x in arr:\r\n            suma += x\r\n    return suma'),\r\n  (7, 1, 'Używając podanych elementów, uzupełnij kod funkcji sprawdzającej czy liczba jest pierwsza w języku Python, aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n        return False\r\n    for i in range(2, int(n0.5) + 1):\r\n    if n <= 1:\r\ndef is_prime(n):\r\n            if n % i == 0:\r\n                return True'),\r\n  (8, 1, 'Używając podanych elementów, uzupełnij kod funkcji odwracającej napis w języku Python, aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n    return s[::-1]\r\ndef reverse_string(s):\r\n    if not s:\r\n        return \"\"'),\r\n  (9, 1, 'Używając podanych elementów, uzupełnij kod funkcji obliczającej średnią z listy liczb w języku Python, aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n    return suma / len(arr)\r\n    suma = 0\r\ndef average(arr):\r\n        for x in arr:\r\n            suma += x\r\n    if not arr:'),\r\n  (10, 2, 'Używając podanych elementów, uzupełnij kod funkcji obliczającej silnię iteracyjnie w języku Java (konsola), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n        long result = 1;\r\n    for (int i = 2; i <= n; i++) {\r\npublic static long silnia(int n) {\r\n        return result;\r\n    if (n <= 1) return 1;'),\r\n  (11, 2, 'Używając podanych elementów, uzupełnij kod funkcji obliczającej n-ty element Fibonacciego w języku Java (konsola), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n    if (n <= 1) return n;\r\npublic static int fib(int n) {\r\n    int a = 0, b = 1;\r\n        int temp = a + b;\r\n    for (int i = 2; i <= n; i++) {\r\n        return b;'),\r\n  (12, 2, 'Używając podanych elementów, uzupełnij kod funkcji sortującej tablicę metodą bąbelkową w języku Java (konsola), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n                int temp = arr[j];\r\n    for (int i = 0; i < n - 1; i++) {\r\npublic static void bubbleSort(int[] arr) {\r\n        for (int j = 0; j < n - i - 1; j++) {\r\n    int n = arr.length;\r\n            if (arr[j] > arr[j + 1]) {'),\r\n  (13, 2, 'Używając podanych elementów, uzupełnij kod funkcji sprawdzającej palindrom w języku Java (konsola), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n    return true;\r\npublic static boolean isPalindrome(String s) {\r\n    s = s.toLowerCase().replaceAll(\"\\\\\\\\s+\", \"\");\r\n    int left = 0, right = s.length() - 1;\r\n        if (s.charAt(left) != s.charAt(right)) return false;\r\n    while (left < right) {'),\r\n  (14, 2, 'Używając podanych elementów, uzupełnij kod funkcji znajdującej maksimum w tablicy w języku Java (konsola), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n    int max = arr[0];\r\npublic static int findMax(int[] arr) {\r\n    if (arr.length == 0) return Integer.MIN_VALUE;\r\n        if (arr[i] > max) max = arr[i];\r\n    for (int i = 1; i < arr.length; i++) {'),\r\n  (15, 2, 'Używając podanych elementów, uzupełnij kod funkcji sumującej elementy tablicy w języku Java (konsola), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n    int sum = 0;\r\npublic static int sumArray(int[] arr) {\r\n        sum += arr[i];\r\n    for (int i = 0; i < arr.length; i++) {\r\n    return sum;'),\r\n  (16, 2, 'Używając podanych elementów, uzupełnij kod funkcji sprawdzającej czy liczba jest pierwsza w języku Java (konsola), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n        return false;\r\n    for (int i = 2; i <= Math.sqrt(n); i++) {\r\npublic static boolean isPrime(int n) {\r\n    if (n <= 1) return false;\r\n            if (n % i == 0) return false;\r\n    return true;'),\r\n  (17, 2, 'Używając podanych elementów, uzupełnij kod funkcji odwracającej tablicę w języku Java (konsola), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n    for (int i = 0; i < n / 2; i++) {\r\npublic static void reverseArray(int[] arr) {\r\n    int n = arr.length;\r\n        int temp = arr[i];\r\n        arr[n - 1 - i] = temp;\r\n    return;'),\r\n  (18, 3, 'Używając podanych elementów, uzupełnij kod metody onCreate w klasie Activity aplikacji mobilnej Android (Java), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n    setContentView(R.layout.activity_main);\r\nprotected void onCreate(Bundle savedInstanceState) {\r\n    super.onCreate(savedInstanceState);\r\n    Button btn = findViewById(R.id.button);\r\n    btn.setOnClickListener(v -> textView.setText(\"Kliknięto!\"));\r\n}'),\r\n  (19, 3, 'Używając podanych elementów, uzupełnij kod obsługi zdarzenia przycisku w aplikacji mobilnej Android (Java), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n    button.setOnClickListener(new View.OnClickListener() {\r\npublic void onClick(View v) {\r\n        count++;\r\n        textView.setText(String.valueOf(count));\r\n    });\r\n}'),\r\n  (20, 3, 'Używając podanych elementów, uzupełnij kod metody startActivity z Intent w aplikacji mobilnej Android (Java), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n    Intent intent = new Intent(this, SecondActivity.class);\r\npublic void openSecondActivity() {\r\n    startActivity(intent);\r\n}'),\r\n  (21, 3, 'Używając podanych elementów, uzupełnij kod zapisu do SharedPreferences w aplikacji mobilnej Android (Java), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n    SharedPreferences.Editor editor = prefs.edit();\r\npublic void saveData(String key, String value) {\r\n    editor.putString(key, value);\r\n    editor.apply();\r\n}'),\r\n  (22, 3, 'Używając podanych elementów, uzupełnij kod listy RecyclerView w aplikacji mobilnej Android (Java), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n    recyclerView.setLayoutManager(new LinearLayoutManager(this));\r\npublic void setupRecyclerView() {\r\n    recyclerView.setAdapter(adapter);\r\n}'),\r\n  (23, 4, 'Używając podanych elementów, uzupełnij kod komponentu licznika w React Native (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n  const [count, setCount] = useState(0);\r\nfunction Counter() {\r\n  return (\r\n    \r\n      Licznik: {count}\r\n      <Button title=\"Zwiększ\" onPress={() => setCount(count + 1)} />\r\n    \r\n  );\r\n}'),\r\n  (24, 4, 'Używając podanych elementów, uzupełnij kod komponentu wyświetlającego listę w React Native (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n  return (\r\nfunction TodoList() {\r\n    <FlatList\r\n      data={todos}\r\n      renderItem={({item}) => {item}}\r\n    />\r\n  );\r\n}'),\r\n  (25, 4, 'Używając podanych elementów, uzupełnij kod komponentu z użyciem useEffect w React Native (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n  useEffect(() => {\r\nfunction App() {\r\n    console.log(\"Komponent zamontowany\");\r\n  }, []);\r\n  return Aplikacja mobilna;\r\n}'),\r\n  (26, 6, 'Używając podanych elementów, uzupełnij kod komponentu React z formularzem logowania w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n  const [email, setEmail] = useState('),\r\n  (27, 6, 'Używając podanych elementów, uzupełnij kod komponentu React z listą zadań (ToDo) w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n  const [todos, setTodos] = useState([]);\r\nfunction TodoApp() {\r\n  const addTodo = () => setTodos([...todos, \"Nowe zadanie\"]);\r\n  return (\r\n    \r\n      {todos.map(t => {t})}\r\n      Dodaj\r\n    \r\n  );\r\n}'),\r\n  (28, 6, 'Używając podanych elementów, uzupełnij kod komponentu React z użyciem fetch do API w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n  useEffect(() => {\r\nfunction DataFetcher() {\r\n    fetch(\"https://api.example.com/data\")\r\n      .then(res => res.json())\r\n      .then(data => setData(data));\r\n  }, []);\r\n  return {data};\r\n}'),\r\n  (29, 6, 'Używając podanych elementów, uzupełnij kod komponentu React z routingiem (React Router) w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n  return (\r\nfunction App() {\r\n    \r\n      \r\n        <Route path=\"/\" element={} />\r\n      \r\n    \r\n  );\r\n}'),\r\n  (30, 6, 'Używając podanych elementów, uzupełnij kod komponentu React z użyciem Context API w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\nconst ThemeContext = createContext();\r\nfunction App() {\r\n  return (\r\n    <ThemeContext.Provider value=\"dark\">\r\n      \r\n    </ThemeContext.Provider>\r\n  );\r\n}'),\r\n  (31, 6, 'Używając podanych elementów, uzupełnij kod komponentu React z reduktorem (useReducer) w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n  const [state, dispatch] = useReducer(reducer, initialState);\r\nfunction CounterReducer() {\r\n  return (\r\n    <button onClick={() => dispatch({type: \"increment\"})}>Zwiększ\r\n  );\r\n}'),\r\n  (32, 6, 'Używając podanych elementów, uzupełnij kod komponentu React z memoizacją (useMemo) w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n  const expensiveValue = useMemo(() => computeExpensiveValue(a, b), [a, b]);\r\nfunction ExpensiveComponent({a, b}) {\r\n  return Wartość: {expensiveValue};\r\n}'),\r\n  (33, 6, 'Używając podanych elementów, uzupełnij kod komponentu React z ref (useRef) w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n  const inputRef = useRef(null);\r\nfunction FocusInput() {\r\n  const focus = () => inputRef.current.focus();\r\n  return ;\r\n}'),\r\n  (34, 6, 'Używając podanych elementów, uzupełnij kod komponentu React z obsługą błędów (Error Boundary) w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\nclass ErrorBoundary extends React.Component {\r\n  componentDidCatch(error, info) {\r\n    this.setState({ hasError: true });\r\n  }\r\n  render() {\r\n    if (this.state.hasError) return Błąd!;\r\n    return this.props.children;\r\n  }\r\n}'),\r\n  (35, 5, 'Używając podanych elementów, uzupełnij kod prostego serwera Node.js z Express w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\napp.get(\"/\", (req, res) => res.send(\"Hello World\"));\r\nconst express = require(\"express\");\r\nconst app = express();\r\napp.listen(3000, () => console.log(\"Serwer działa\"));'),\r\n  (36, 5, 'Używając podanych elementów, uzupełnij kod middleware w Node.js (JS) do logowania żądań w aplikacji webowej, aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\napp.use((req, res, next) => {\r\n  console.log(${req.method} \\\\( {req.url});\r\n  next();\r\n});\r\n'),\r\n  (37, 5, 'Używając podanych elementów, uzupełnij kod routingu REST API w Node.js (JS) w aplikacji webowej, aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\napp.post(\"/users\", (req, res) => {\r\n  res.json({ id: 1, name: req.body.name });\r\n});\r\n'),\r\n  (38, 6, 'Używając podanych elementów, uzupełnij kod komponentu React z obsługą stanu asynchronicznego w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n  const [loading, setLoading] = useState(true);\r\nfunction AsyncComponent() {\r\n  useEffect(() => {\r\n    fetchData().then(() => setLoading(false));\r\n  }, []);\r\n  if (loading) return Ładowanie...;\r\n}'),\r\n  (39, 6, 'Używając podanych elementów, uzupełnij kod komponentu React z props drilling w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\nfunction Parent() {\r\n  const value = \"Dane\";\r\n  return ;\r\n}\r\nfunction Child({value}) {\r\n  return {value};\r\n}'),\r\n  (40, 6, 'Używając podanych elementów, uzupełnij kod komponentu React z custom hook w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\nfunction useCounter() {\r\n  const [count, setCount] = useState(0);\r\n  const increment = () => setCount(c => c + 1);\r\n  return {count, increment};\r\n}\r\nfunction Counter() {\r\n  const {count, increment} = useCounter();\r\n  return {count};\r\n}'),\r\n  (41, 6, 'Używając podanych elementów, uzupełnij kod komponentu React z portalem (React Portal) w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\nfunction Modal({children}) {\r\n  return createPortal(children, document.getElementById(\"modal-root\"));\r\n}\r\n'),\r\n  (42, 6, 'Używając podanych elementów, uzupełnij kod komponentu React z Suspense w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n  <Suspense fallback={Ładowanie...}>\r\nfunction LazyApp() {\r\n    \r\n  \r\n}'),\r\n  (43, 6, 'Używając podanych elementów, uzupełnij kod obsługi błędu w komponencie React w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n  throw new Error(\"Błąd testowy\");\r\nfunction BuggyComponent() {\r\n  return OK;\r\n}'),\r\n  (44, 6, 'Używając podanych elementów, uzupełnij kod komponentu React z animacją (framer-motion) w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n<motion.div animate={{ scale: 1.2 }}>\r\nfunction AnimatedBox() {\r\n  return <motion.div animate={{ scale: 1.2 }}>Animacja</motion.div>;\r\n}'),\r\n  (45, 6, 'Używając podanych elementów, uzupełnij kod komponentu React z dark mode toggle w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n  const [theme, setTheme] = useState(\"light\");\r\nfunction ThemeToggle() {\r\n  const toggle = () => setTheme(theme === \"light\" ? \"dark\" : \"light\");\r\n  return Przełącz;\r\n}'),\r\n  (46, 6, 'Używając podanych elementów, uzupełnij kod komponentu React z lokalizacją (i18n) w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n  const { t } = useTranslation();\r\nfunction LocalizedComponent() {\r\n  return {t(\"hello\")};\r\n}'),\r\n  (47, 6, 'Używając podanych elementów, uzupełnij kod komponentu React z walidacją formularza w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n  if (!email) return \"Brak email\";\r\nfunction FormValidator() {\r\n  const [email, setEmail] = useState(\"\");\r\n  return <input onChange={e => setEmail(e.target.value)} />;\r\n}'),\r\n  (48, 6, 'Używając podanych elementów, uzupełnij kod komponentu React z drag and drop w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n  onDrop={handleDrop}\r\nfunction DragDrop() {\r\n  return Przeciągnij;\r\n}'),\r\n  (49, 6, 'Używając podanych elementów, uzupełnij kod komponentu React z testowaniem (Jest) w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\ntest(\"renderuje poprawnie\", () => {\r\n  render();\r\n  expect(screen.getByText(\"Hello\")).toBeInTheDocument();\r\n});\r\n'),\r\n  (50, 6, 'Używając podanych elementów, uzupełnij kod komponentu React z optymalizacją (React.memo) w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\nconst Memoized = React.memo(function Child({value}) {\r\n  return {value};\r\n});\r\n'),\r\n  (51, 6, 'Używając podanych elementów, uzupełnij kod komponentu React z hookiem useCallback w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n  const memoizedCallback = useCallback(() => {\r\nfunction CallbackComponent() {\r\n    doSomething(a, b);\r\n  }, [a, b]);\r\n}'),\r\n  (52, 6, 'Używając podanych elementów, uzupełnij kod komponentu React z lazy loading w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\nconst LazyComponent = lazy(() => import(\"./LazyComponent\"));\r\nfunction App() {\r\n  return <Suspense fallback={Ładowanie...}>;\r\n}'),\r\n  (53, 6, 'Używając podanych elementów, uzupełnij kod komponentu React z strict mode w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n  <React.StrictMode>\r\nfunction Root() {\r\n    \r\n  </React.StrictMode>\r\n}'),\r\n  (54, 6, 'Używając podanych elementów, uzupełnij kod komponentu React z concurrent mode (startTransition) w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n  startTransition(() => setTab(tab));\r\nfunction TabSwitcher() {\r\n  const [tab, setTab] = useState(0);\r\n}'),\r\n  (55, 6, 'Używając podanych elementów, uzupełnij kod komponentu React z server components w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\nasync function ServerComponent() {\r\n  const data = await fetchData();\r\n  return {data};\r\n}\r\n'),\r\n  (56, 6, 'Używając podanych elementów, uzupełnij kod komponentu React z action w aplikacji webowej (JS), aby działał poprawnie.\r\n\r\nPodane fragmenty kodu:\r\n  \"use server\";\r\nasync function createUser(formData) {\r\n  // logika\r\n}\r\n')"
